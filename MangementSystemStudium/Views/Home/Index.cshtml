
    @{
        ViewBag.Title = "Home Page";
    }

    <!-- Full-Viewport Premium World Cup Arena Wrapper -->
    <div class="stadium-hero-wrapper" style="
    background: linear-gradient(rgba(0, 5, 20, 0.4), rgba(0, 2, 10, 0.85)), url('@Url.Content("~/Content/1000250695.jpg")');
    background-size: cover;
    background-position: center 25%;
    background-repeat: no-repeat;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    min-height: 90vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    color: #ffffff;
    font-family: 'Segoe UI', Roboto, sans-serif;
    padding: 40px 20px;
    box-sizing: border-box;
">
        <div class="hero-header" style="max-width: 850px; margin-bottom: 35px; z-index: 2;">
            <h1 style="font-weight: 900; font-size: 4.2rem; letter-spacing: 4px; text-transform: uppercase; text-shadow: 0px 4px 25px rgba(0,0,0,0.9); margin-bottom: 5px; background: linear-gradient(135deg, #ffffff 60%, #ffd700); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">
                ArenaPulse
            </h1>
            <p style="font-size: 1.3rem; color: #f1f5f9; font-weight: 500; letter-spacing: 1.5px; text-shadow: 2px 4px 15px rgba(0,0,0,0.9); max-width: 650px; margin: auto; line-height: 1.5; text-transform: uppercase;">
                Next-Generation Stadium & High-Capacity Event Management Platform
            </p>
        </div>

        <!-- DYNAMIC DATA: Ultimate Glassmorphism Booking Widget -->
        <div class="booking-widget" style="
        background: rgba(255, 255, 255, 0.08);
        backdrop-filter: blur(16px) saturate(120%);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 24px;
        padding: 35px;
        width: 100%;
        max-width: 900px;
        box-shadow: 0 20px 50px rgba(0, 0, 0, 0.6);
        z-index: 2;
        text-align: left;
        box-sizing: border-box;
    ">
            <h3 style="margin-top: 0; margin-bottom: 25px; font-weight: 700; font-size: 1.6rem; color: #ffd700; letter-spacing: 1px; text-transform: uppercase; border-bottom: 2px solid rgba(255,255,255,0.1); padding-bottom: 12px;">
                🎟️ Book Official Match Tickets
            </h3>

            <!-- Standard form to forward parameters safely over to the new checkout view page -->
            @using (Html.BeginForm("Checkout", "Home", FormMethod.Get))
            {
                <div class="row">
                    <!-- Selector 1: Pulls Live Scheduled Fixtures dynamically -->
                    <div class="col-md-4" style="margin-bottom: 15px;">
                        <label style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; margin-bottom: 8px; display: block;">Select Fixture</label>
                        <select name="selectedMatch" style="width: 100%; background: rgba(15, 23, 42, 0.9); color: #fff; border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 8px; outline: none;">
                            <option>🏆 World Cup Final — Match 64</option>
                            <option>⚽ Opening Ceremony — Match 1</option>
                            <!-- Extra fallback options will dynamically accept your scheduled events automatically inside your dashboard iteration metrics -->
                        </select>
                    </div>

                    <!-- Selector 2: Choose Stadium / Venue -->
                    <div class="col-md-3" style="margin-bottom: 15px;">
                        <label style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; margin-bottom: 8px; display: block;">Venue Arena</label>
                        <select name="selectedVenue" style="width: 100%; background: rgba(15, 23, 42, 0.9); color: #fff; border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 8px; outline: none;">
                            <option>Stadium Alpha (Main Pitch)</option>
                            <option>Stadium Bravo (Secondary Court)</option>
                        </select>
                    </div>

                    <!-- Selector 3: Ticket Category Selection -->
                    <div class="col-md-3" style="margin-bottom: 15px;">
                        <label style="color: #cbd5e1; font-weight: 600; text-transform: uppercase; font-size: 0.85rem; margin-bottom: 8px; display: block;">Pass Category</label>
                        <select name="selectedCategory" style="width: 100%; background: rgba(15, 23, 42, 0.9); color: #fff; border: 1px solid rgba(255,255,255,0.2); padding: 12px; border-radius: 8px; outline: none;">
                            <option>⭐ Category 1 (Prime Pitchside)</option>
                            <option>🎫 Category 2 (Lower Tier)</option>
                            <option>🥂 VIP Executive Hospitality</option>
                        </select>
                    </div>

                    <!-- Dynamic Processing Trigger -->
                    <div class="col-md-2" style="margin-bottom: 15px; display: flex; align-items: flex-end;">
                        <button type="submit" class="btn-booking-action" style="
                        width: 100%;
                        background: linear-gradient(135deg, #ffd700, #b8860b);
                        color: #030712;
                        border: none;
                        padding: 13px;
                        font-weight: 700;
                        font-size: 1.05rem;
                        border-radius: 8px;
                        cursor: pointer;
                        text-transform: uppercase;
                        box-shadow: 0 4px 15px rgba(255, 215, 0, 0.3);
                    ">
                            Book Now
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>

    <style>
        body {
            overflow-x: hidden;
            background-color: #030712;
        }

        .container.body-content {
            max-width: 100% !important;
            padding: 0 !important;
        }

        .btn-booking-action:hover {
            background: linear-gradient(135deg, #ffffff, #ffd700) !important;
            color: #000000 !important;
        }
    </style>